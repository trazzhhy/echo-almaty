DATABASE_URL="postgresql://postgres:postgres@localhost:5432/echo_almaty?schema=public"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
ADMIN_PANEL_SECRET="replace-with-a-long-random-secret"
CRON_SECRET="replace-with-a-second-long-random-secret"

# local | s3
STORAGE_DRIVER="local"

# S3-compatible storage settings for production deployments.
# Example providers: AWS S3, Cloudflare R2, MinIO, DigitalOcean Spaces.
STORAGE_PUBLIC_BASE_URL="https://cdn.example.com"
STORAGE_S3_REGION="auto"
STORAGE_S3_BUCKET="echo-almaty"
STORAGE_S3_ENDPOINT="https://example-r2-endpoint.com"
STORAGE_S3_ACCESS_KEY_ID="replace-me"
STORAGE_S3_SECRET_ACCESS_KEY="replace-me"
STORAGE_S3_FORCE_PATH_STYLE="false"
STORAGE_S3_PREFIX="uploads"
